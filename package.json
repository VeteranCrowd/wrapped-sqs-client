{
  "name": "@veterancrowd/wrapped-sqs-client",
  "version": "0.0.7",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VeteranCrowd/wrapped-sqs-client"
  },
  "author": "Jason G. Williscroft",
  "bugs": {
    "url": "https://github.com/VeteranCrowd/wrapped-sqs-client/issues"
  },
  "description": "An AWS SQS client wrapped to provide consistent logging and other services.",
  "homepage": "https://github.com/VeteranCrowd/wrapped-sqs-client#readme",
  "keywords": [],
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.267.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/cli": "^7.20.7",
    "@babel/core": "^7.20.12",
    "@babel/eslint-parser": "^7.19.1",
    "@babel/plugin-syntax-import-assertions": "^7.20.0",
    "@babel/preset-env": "^7.20.2",
    "@babel/register": "^7.18.9",
    "@karmaniverous/get-dotenv": "^0.2.3",
    "@types/node": "^18.13.0",
    "babel-plugin-lodash": "^3.3.4",
    "chai": "^4.3.7",
    "chai-match-pattern": "^1.3.0",
    "concat-md": "^0.5.0",
    "eslint": "^8.34.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-jsdoc": "^40.0.0",
    "eslint-plugin-mocha": "^10.1.0",
    "jsdoc-to-markdown": "^8.0.0",
    "mocha": "^10.2.0",
    "prettier": "^2.8.4",
    "release-it": "^15.6.0",
    "uuid": "^9.0.0"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./dist/default/lib/index.js"
    }
  },
  "main": "./lib/index.js",
  "mocha": {
    "exclude": [
      "./dist/**",
      "./node_modules/**"
    ],
    "file": "./test-setup.js",
    "require": [
      "@babel/register",
      "chai-match-pattern"
    ],
    "spec": "./**/*.test.!(*.*)",
    "timeout": 10000
  },
  "release-it": {
    "github": {
      "release": true
    },
    "npm": {
      "publish": true
    }
  },
  "scripts": {
    "lint": "eslint lib/**",
    "test": "mocha",
    "build": "babel lib -d dist/default/lib --delete-dir-on-start --config-file ./dist/default/.babelrc",
    "doc": "jsdoc2md -c doc/jsdoc.config.json -f lib/**/*.* -t doc/api-template.hbs > doc/2-api.jsdoc2.md && concat-md doc --hide-anchor-links > README.md",
    "package": "npm run lint && npm run test && npm run build && npm run doc",
    "release": "npm run package && getdotenv -- release-it"
  },
  "type": "module"
}
